# ─── Dependencias Node.js ────────────────────────────────────────────────────
node_modules/
package-lock.json

# ─── Variables de entorno (contienen credenciales) ───────────────────────────
.env
# .env.example sí se versiona (contiene solo nombres de variables, sin valores)

# ─── Logs de Node / npm ──────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# ─── Archivos de sistema operativo ───────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ─── Editores e IDEs ─────────────────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# ─── Cobertura de tests y builds ─────────────────────────────────────────────
coverage/
dist/
build/

# ─── Archivos temporales ─────────────────────────────────────────────────────
*.tmp
*.temp
